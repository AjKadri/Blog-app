<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<title>AJ's Blog App</title>

		<link
			href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
			rel="stylesheet"
		/>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<link rel="stylesheet" href="/styles/main.css" />
	</head>

	<body class="d-flex flex-column min-vh-100">
		<header><%- include('./partials/header.ejs' ) %></header>
		<main class="container flex-grow-1 py-4">
			<h1 class="text-center">Edit Post</h1>
			<p class="text-center">Edit your blog post.</p>

            <!--  I should have added a form here to submit the title and content of the post.
            The form should have an action that points to the route that handles the post submission, and it should use the POST method.
            The form should include input fields for the title and content, as well as a submit button. -->

            <!-- <input name="title" type="text" class="form-control" placeholder="Title" />
            <textarea name="content" class="form-control" rows="19" placeholder="Content"></textarea>
            <input type="submit" value="SAVE" /> -->

            <form action="/posts/<%= post.id %>/edit" method="POST">
				<h4> <label class="form-label" placeholder="Title">Title</label></h4>
				<input type="text" name="title" class="form-control" value="<%= post.title %>">

				<h4><label class="form-label" >Content</label></h4>
				<textarea name="content" class="form-control" rows="15"><%= post.content %></textarea>

				<button class="btn btn-success mt-3">
					Save Changes
				</button>
			</form>

		</main>
		<footer>
			<%- include('./partials/footer.ejs') %>
		</footer>
	</body>
</html>