<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<title>AJ's Blog App</title>

		<link
			href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
			rel="stylesheet"
		/>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<link rel="stylesheet" href="/styles/main.css" />
	</head>

	<body>
		<header><%- include('./partials/header.ejs' ) %></header>

		<section class="hero">
			<div class="container">
				<div class="row align-items-center">
					<div class="col-lg-6">
						<span class="badge rounded-pill text-bg-primary mb-3">
							Welcome 👋
						</span>

						<h1 class="display-3 fw-bold">Write. Share. Inspire.</h1>

						<p class="lead text-secondary">
							A clean blog platform built with Node.js, Express, Bootstrap, and
							EJS. Create, edit and manage your posts with ease.
						</p>

						<div class="mt-4">
							<a href="/compose" class="btn btn-primary btn-lg me-3">
								<i class="bi bi-pencil-fill"></i>
								Write Your First Post
							</a>

							<a href="/posts" class="btn btn-outline-dark btn-lg">
								Browse Posts
							</a>
						</div>
					</div>

					<div class="col-lg-6 text-center">
						<img
							src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=900"
							class="img-fluid rounded-4 shadow"
							alt="Blog"
						/>
					</div>
				</div>
			</div>
		</section>

		<!-- FEATURES -->

		<section class="py-5">
			<div class="container">
				<h2 class="text-center fw-bold mb-5">Everything You Need</h2>

				<div class="row g-4">
					<div class="col-md-4">
						<div class="card feature-card">
							<div class="card-body">
								<div class="icon">
									<i class="bi bi-pencil-square"></i>
								</div>

								<h4>Create Posts</h4>

								<p>Write beautiful blog posts using a clean interface.</p>
							</div>
						</div>
					</div>

					<div class="col-md-4">
						<div class="card feature-card">
							<div class="card-body">
								<div class="icon">
									<i class="bi bi-book"></i>
								</div>

								<h4>Read Posts</h4>

								<p>Browse articles from your collection anytime.</p>
							</div>
						</div>
					</div>

					<div class="col-md-4">
						<div class="card feature-card">
							<div class="card-body">
								<div class="icon">
									<i class="bi bi-gear"></i>
								</div>

								<h4>Manage</h4>

								<p>Edit and delete posts whenever you need.</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA -->

		<section class="cta">
			<div class="container text-center">
				<h2 class="fw-bold">Ready to start writing?</h2>

				<p class="lead">Create your very first article today.</p>

				<a href="/compose" class="btn btn-light btn-lg"> Start Writing </a>
			</div>
		</section>

		<!-- FOOTER -->

		<footer>
			<%- include('./partials/footer.ejs') %>
		</footer>

		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
	</body>
</html>
